# IPRMS — local environment configuration (EXAMPLE)
# Copy to .env and fill in ONLY if you enable the controlled fallback features.
# The deterministic core pipeline runs fully WITHOUT any of these, and final
# decisions stay identical with LLM fallback disabled (plan §4.1).

# --- Controlled LLM fallback (LangChain) — OFF by default ---
# Allowed at exactly TWO points; LLM output is advisory and never decides
# budget, vendor, compliance, split-order, routing, or PO rules:
#   1. Agent A — PR-type classification (standard/emergency/capex) when metadata
#      cannot classify it.
#   2. Agent B — vague item descriptions / unclear OCR-PDF extraction.
IPRMS_LLM_FALLBACK_ENABLED=false
# OPENAI_API_KEY=
# IPRMS_LLM_MODEL=

# --- OCR engine for scanned PDFs (pytesseract) ---
# Path to the system Tesseract binary, if it is not on PATH.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- LangGraph internal A->H skeleton toggle ---
# LangGraph only provides shared state, routing, fallback control, and audit
# trail; its output must match the direct deterministic Python pipeline.
IPRMS_USE_LANGGRAPH=false
